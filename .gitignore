# === dependencies ===
node_modules/
.pnp
.pnp.js

# === build outputs ===
.next/
out/
build/
dist/
coverage/

# === env ===
.env
.env.local
.env.*.local
!.env.example

# === python / uv ===
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
