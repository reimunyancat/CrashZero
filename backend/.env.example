PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# data.go.kr (도로교통공단 사고다발지역, 어린이/보행자 사고)
DATA_GO_KR_KEY=

# V-World (시설 / 도로명)
VWORLD_KEY=

# 기상청 (단기예보)
KMA_KEY=

# OSM Overpass mirror (optional — defaults to overpass-api.de)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Fallback fixtures (true to force offline mode)
USE_FIXTURES=false
FIXTURES_DIR=../frontend/public/fixtures
