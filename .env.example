# --- Public Data Portal (data.go.kr) -------------------------------
# Issued at https://www.data.go.kr — used for KOROAD frequentzone APIs.
DATA_GO_KR_SERVICE_KEY=
KOROAD_SERVICE_KEY=
PUBLIC_DATA_SERVICE_KEY=

# --- V-World (vworld.kr) -------------------------------------------
# Issued at https://www.vworld.kr — basemap tiles + WFS road network.
VWORLD_KEY=

# --- KMA (data.kma.go.kr) ------------------------------------------
# Issued at https://apihub.kma.go.kr — weather observations + forecasts.
KMA_SERVICE_KEY=

PORT=4000
NODE_ENV=development
LOG_LEVEL=info
CACHE_TTL_SECONDS=900

NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_VWORLD_KEY=
NEXT_PUBLIC_USE_FIXTURE=false
